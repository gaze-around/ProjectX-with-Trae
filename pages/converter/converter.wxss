.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.converter {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.category-selector {
  margin-bottom: 30rpx;
}

.category-scroll {
  white-space: nowrap;
  padding-bottom: 10rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 15rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
}

.category-item.active {
  background: #1677FF;
  color: white;
  transform: translateY(-2rpx);
}

.conversion-area {
  margin-bottom: 30rpx;
}

.input-section,
.output-section {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 32rpx;
  margin-bottom: 15rpx;
}

.output {
  width: 100%;
  padding: 20rpx;
  background: #f8f8f8;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 15rpx;
}

.unit-picker {
  padding: 15rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

.picker-text {
  display: inline-block;
}

.swap-button {
  text-align: center;
  margin: 20rpx 0;
  padding: 15rpx;
}

.swap-icon {
  font-size: 48rpx;
  color: #1677FF;
  cursor: pointer;
  transition: transform 0.3s ease;
}

.swap-button:active .swap-icon {
  transform: rotate(180deg);
}

.history-section {
  margin-top: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 15rpx;
  padding-left: 10rpx;
  border-left: 4rpx solid #1677FF;
}

.history-list {
  max-height: 200rpx;
  overflow-y: auto;
}

.history-item {
  padding: 15rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.empty-history {
  padding: 40rpx;
  text-align: center;
  color: #999;
  font-size: 24rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
}