<view class="container">
  <view class="header">
    <text class="title">设置</text>
  </view>
  
  <view class="settings-list">
    <view class="setting-section">
      <text class="section-title">数据管理</text>
      <view class="setting-item" bindtap="clearHistory">
        <text class="setting-label">清除历史记录</text>
        <text class="setting-arrow">→</text>
      </view>
    </view>
    
    <view class="setting-section">
      <text class="section-title">外观设置</text>
      <view class="setting-item">
        <text class="setting-label">深色模式</text>
        <switch class="setting-switch" bindchange="toggleDarkMode" />
      </view>
    </view>
    
    <view class="setting-section">
      <text class="section-title">关于</text>
      <view class="setting-item">
        <text class="setting-label">版本号</text>
        <text class="setting-value">1.0.0</text>
      </view>
      <view class="setting-item" bindtap="showAbout">
        <text class="setting-label">关于我们</text>
        <text class="setting-arrow">→</text>
      </view>
      <view class="setting-item" bindtap="showPrivacy">
        <text class="setting-label">隐私政策</text>
        <text class="setting-arrow">→</text>
      </view>
    </view>
  </view>
  
  <view class="footer">
    <text class="footer-text">实用工具 © 2026</text>
  </view>
</view>