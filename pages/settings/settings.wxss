.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.settings-list {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.setting-section {
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-section:last-child {
  border-bottom: none;
}

.section-title {
  font-size: 24rpx;
  color: #999;
  padding: 20rpx 30rpx 10rpx;
  font-weight: 500;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 25rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  transition: background-color 0.3s ease;
}

.setting-item:first-child {
  border-top: none;
}

.setting-item:hover {
  background-color: #f8f8f8;
}

.setting-label {
  font-size: 28rpx;
  color: #333;
}

.setting-value {
  font-size: 26rpx;
  color: #999;
}

.setting-arrow {
  font-size: 24rpx;
  color: #999;
}

.setting-switch {
  transform: scale(1.2);
}

.footer {
  text-align: center;
  margin-top: 60rpx;
  padding: 20rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
}